---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const beans = [
  {
    name: 'Ethiopia Yirgacheffe',
    roast: 'Light',
    process: 'Washed',
    notes: 'Jasmine · Bergamot · Lemon Zest',
    altitude: '1,750–2,200m',
    price: '$22',
    imgUrl: 'https://images.unsplash.com/photo-1611854779393-1b2da9d400fe?auto=format&fit=crop&q=80&w=800&h=900',
    imgAlt: 'Ethiopia Yirgacheffe green coffee cherries on a farm',
  },
  {
    name: 'Colombia Huila',
    roast: 'Medium',
    process: 'Honey',
    notes: 'Dark Cherry · Brown Sugar · Hazelnut',
    altitude: '1,600–1,950m',
    price: '$20',
    imgUrl: 'https://images.unsplash.com/photo-1447933601403-0c6688de566e?auto=format&fit=crop&q=80&w=800&h=900',
    imgAlt: 'Colombia Huila coffee farm with mountains in the background',
  },
  {
    name: 'Guatemala Antigua',
    roast: 'Medium-Dark',
    process: 'Natural',
    notes: 'Dark Chocolate · Dried Fig · Spice',
    altitude: '1,500–1,700m',
    price: '$19',
    imgUrl: 'https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?auto=format&fit=crop&q=80&w=800&h=900',
    imgAlt: 'Guatemala Antigua dark roast coffee in a cup',
  },
];

const steps = [
  {
    step: '01',
    title: 'Direct Sourcing',
    desc: 'We visit farms personally, building long-term relationships with the growers who make our coffee possible.',
  },
  {
    step: '02',
    title: 'Green Selection',
    desc: 'Every lot is cupped blind. Only beans scoring 85+ make the cut — we buy small lots to guarantee quality.',
  },
  {
    step: '03',
    title: 'Artisan Roasting',
    desc: 'Roasted to order on our Loring S35. Each origin gets a custom profile developed over dozens of iterations.',
  },
  {
    step: '04',
    title: 'Same-Week Ship',
    desc: 'Roasted Monday, shipped Wednesday. You receive peak freshness — the sweet spot between 4–14 days off-roast.',
  },
];

const plans = [
  {
    name: 'The Explorer',
    price: '$38',
    freq: '/month',
    bags: '2 × 250g',
    desc: 'Two rotating single origins each month — our picks, always a surprise.',
    highlight: false,
  },
  {
    name: 'The Purist',
    price: '$58',
    freq: '/month',
    bags: '4 × 250g',
    desc: 'Your choice of origins, grind, and roast level. Consistent, perfect, yours.',
    highlight: true,
  },
  {
    name: 'The Devotee',
    price: '$95',
    freq: '/month',
    bags: '8 × 250g',
    desc: 'Rotate everything or lock in your favourites — we keep the shelf stocked.',
    highlight: false,
  },
];
---

<Layout>
  <!-- Navigation -->
  <header class="sticky top-0 z-40 bg-[#F5F0E8]/95 backdrop-blur-sm border-b border-[#3C2A21]/10">
    <nav
      class="max-w-7xl mx-auto px-6 md:px-8 h-16 flex items-center justify-between"
      aria-label="Main navigation"
    >
      <a href="/" class="flex items-center gap-3" aria-label="Beanz home">
        <svg class="w-8 h-8 text-[#E57C23]" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <ellipse cx="16" cy="16" rx="13" ry="10" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="2"/>
          <path d="M16 6 Q22 10 22 16 Q22 22 16 26 Q10 22 10 16 Q10 10 16 6Z" fill="currentColor" opacity="0.3"/>
          <path d="M16 8 Q16 16 16 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="text-xl font-serif font-black tracking-tighter uppercase italic text-[#3C2A21]">Beanz</span>
      </a>

      <div class="hidden md:flex items-center gap-10">
        <a href="#beans"     class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest text-[#3C2A21]/70 hover:text-[#E57C23] transition-colors">The Beans</a>
        <a href="#process"   class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest text-[#3C2A21]/70 hover:text-[#E57C23] transition-colors">Our Process</a>
        <a href="#subscribe" class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest text-[#3C2A21]/70 hover:text-[#E57C23] transition-colors">Subscribe</a>
        <a href="#subscribe" class="bg-[#3C2A21] text-[#D5CEA3] font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest px-5 py-2.5 rounded-full hover:bg-[#E57C23] transition-colors">
          Order Beans
        </a>
      </div>

      <button
        id="menu-toggle"
        class="md:hidden p-2 text-[#3C2A21]"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/>
        </svg>
      </button>
    </nav>

    <div id="mobile-menu" class="hidden md:hidden border-t border-[#3C2A21]/10 bg-[#F5F0E8] px-6 pb-6 pt-4 flex-col gap-5" role="menu">
      <a href="#beans"     class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest text-[#3C2A21]/70" role="menuitem">The Beans</a>
      <a href="#process"   class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest text-[#3C2A21]/70" role="menuitem">Our Process</a>
      <a href="#subscribe" class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest text-[#3C2A21]/70" role="menuitem">Subscribe</a>
      <a href="#subscribe" class="bg-[#3C2A21] text-[#D5CEA3] font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest px-5 py-3 rounded-full text-center" role="menuitem">Order Beans</a>
    </div>
  </header>

  <main id="main">

    <!-- Hero -->
    <section class="px-6 md:px-8 py-20 md:py-28 max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative z-10">
        <p class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-[0.4em] text-[#E57C23] mb-6">
          Small Batch &middot; Direct Trade &middot; Portland, OR
        </p>
        <h1 class="font-serif text-6xl md:text-8xl font-black leading-[0.9] mb-8 uppercase italic text-[#3C2A21]">
          From seed<br/>
          to your<br/>
          <span class="text-[#E57C23]">morning cup.</span>
        </h1>
        <p class="text-lg max-w-md leading-relaxed mb-12 text-[#3C2A21]/75">
          We source, roast, and ship extraordinary single-origin coffees — each lot hand-selected from farms we know by name, roasted to order, shipped within 48 hours.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="#beans"
            class="bg-[#E57C23] text-white font-['JetBrains_Mono'] font-bold text-[11px] uppercase tracking-widest px-8 py-4 rounded-full flex items-center gap-3 hover:bg-[#cf6d1a] transition-colors group"
          >
            Explore Our Beans
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="#subscribe"
            class="font-['JetBrains_Mono'] font-bold text-[11px] uppercase tracking-widest px-8 py-4 rounded-full border-2 border-[#3C2A21]/20 hover:border-[#E57C23] transition-colors text-[#3C2A21]/80"
          >
            Subscribe &amp; Save
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="aspect-[4/5] bg-[#D5CEA3] rounded-[2rem] overflow-hidden rotate-1 shadow-2xl relative">
          <Image
            src="https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?auto=format&fit=crop&q=80&w=900&h=1125"
            alt="Freshly roasted coffee beans spilling from a roasting drum"
            width={900}
            height={1125}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#3C2A21]/70 to-transparent"></div>
          <div class="absolute bottom-10 left-10 text-[#D5CEA3]">
            <p class="font-['JetBrains_Mono'] text-[10px] font-bold uppercase tracking-[0.3em] mb-2 opacity-75">Today's Roast</p>
            <p class="font-serif text-2xl font-black italic uppercase leading-tight">Ethiopia<br/>Yirgacheffe</p>
            <p class="font-['JetBrains_Mono'] text-sm opacity-60 mt-1">Light &middot; Washed &middot; 1,900m</p>
          </div>
        </div>
        <!-- Decorative badge -->
        <div class="absolute -bottom-6 -left-6 w-28 h-28 bg-[#E57C23] rounded-full hidden lg:flex items-center justify-center -rotate-12 shadow-xl" aria-hidden="true">
          <p class="font-['JetBrains_Mono'] text-[9px] font-bold uppercase tracking-widest text-white text-center leading-relaxed">Roasted<br/>Today</p>
        </div>
        <!-- Score badge -->
        <div class="absolute -top-4 -right-4 hidden lg:block bg-[#F5F0E8] border-2 border-[#3C2A21]/10 rounded-2xl px-5 py-3 shadow-lg rotate-2" aria-hidden="true">
          <p class="font-['JetBrains_Mono'] text-[9px] font-bold uppercase tracking-widest text-[#3C2A21]/50 mb-0.5">SCA Score</p>
          <p class="font-serif text-3xl font-black text-[#3C2A21]">92<span class="text-[#E57C23] text-base">.5</span></p>
        </div>
      </div>
    </section>

    <!-- Ticker -->
    <div class="bg-[#3C2A21] py-4 overflow-hidden border-y-2 border-[#E57C23]" aria-hidden="true">
      <div class="flex whitespace-nowrap animate-marquee">
        {Array.from({ length: 14 }).map(() => (
          <span class="font-['JetBrains_Mono'] text-[#D5CEA3] text-xs font-bold uppercase tracking-[0.5em] mx-10 flex-shrink-0">
            Direct Trade &bull; Small Batch Roasted &bull; Ethically Sourced &bull; Fresh Weekly &bull;
          </span>
        ))}
      </div>
    </div>

    <!-- Featured Beans -->
    <section id="beans" class="py-24 px-6 md:px-8 bg-[#D5CEA3]/20">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-0.5 bg-[#E57C23]" aria-hidden="true"></div>
          <p class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-[0.4em] text-[#E57C23]">Single Origins</p>
        </div>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
          <h2 class="font-serif text-5xl md:text-6xl font-black uppercase italic leading-tight text-[#3C2A21]">
            Current<br/>Offerings
          </h2>
          <p class="max-w-sm text-[#3C2A21]/65 leading-relaxed text-sm">
            Lots rotate with each harvest season. We only carry what's in its peak window of freshness.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {beans.map((bean, i) => (
            <article class="group bg-[#F5F0E8] border-2 border-[#3C2A21]/5 rounded-3xl overflow-hidden hover:border-[#E57C23] hover:-translate-y-1 transition-all duration-300">
              <div class="aspect-[4/5] overflow-hidden bg-[#D5CEA3]">
                <Image
                  src={bean.imgUrl}
                  alt={bean.imgAlt}
                  width={800}
                  height={900}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-7">
                <div class="flex justify-between items-start mb-4">
                  <div class="flex gap-2 flex-wrap">
                    <span class="font-['JetBrains_Mono'] text-[10px] font-bold uppercase tracking-widest bg-[#D5CEA3] px-3 py-1 rounded-full text-[#3C2A21]/70">{bean.roast}</span>
                    <span class="font-['JetBrains_Mono'] text-[10px] font-bold uppercase tracking-widest bg-[#D5CEA3] px-3 py-1 rounded-full text-[#3C2A21]/70">{bean.process}</span>
                  </div>
                  <span class="font-['JetBrains_Mono'] font-bold text-[#E57C23] text-lg">{bean.price}</span>
                </div>
                <h3 class="font-serif text-2xl font-black uppercase italic text-[#3C2A21] mb-2">{bean.name}</h3>
                <p class="font-['JetBrains_Mono'] text-xs text-[#3C2A21]/50 mb-4 uppercase tracking-widest">{bean.altitude} altitude</p>
                <p class="text-sm text-[#3C2A21]/65 mb-6">{bean.notes}</p>
                <button class="w-full bg-[#3C2A21] text-[#D5CEA3] font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest py-3 rounded-xl hover:bg-[#E57C23] transition-colors cursor-pointer">
                  Add to Bag — {bean.price}
                </button>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Gallery -->
    <section class="py-16 px-6 md:px-8 max-w-7xl mx-auto" aria-label="Roastery gallery">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 items-end">
        {[
          { src: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=600&h=700', alt: 'Latte art in a white ceramic cup', w: 600, h: 700, cls: 'h-64 md:h-80' },
          { src: 'https://images.unsplash.com/photo-1544644181-1484b3fdfc62?auto=format&fit=crop&q=80&w=600&h=500', alt: 'Green coffee beans in a burlap sack',         w: 600, h: 500, cls: 'h-48 md:h-56' },
          { src: 'https://images.unsplash.com/photo-1459755486867-b55449bb39ff?auto=format&fit=crop&q=80&w=600&h=600', alt: 'Roasted coffee beans macro close-up',          w: 600, h: 600, cls: 'h-56 md:h-64' },
          { src: 'https://images.unsplash.com/photo-1521017432531-fbd92d768814?auto=format&fit=crop&q=80&w=600&h=700', alt: 'Barista preparing a pour-over coffee',          w: 600, h: 700, cls: 'h-64 md:h-80' },
        ].map(({ src, alt, w, h, cls }) => (
          <div class={`${cls} rounded-2xl overflow-hidden bg-[#D5CEA3]`}>
            <Image src={src} alt={alt} width={w} height={h} loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          </div>
        ))}
      </div>
    </section>

    <!-- Process -->
    <section id="process" class="py-24 px-6 md:px-8 bg-[#3C2A21]">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-0.5 bg-[#E57C23]" aria-hidden="true"></div>
          <p class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-[0.4em] text-[#E57C23]">How We Do It</p>
        </div>
        <h2 class="font-serif text-5xl md:text-6xl font-black uppercase italic leading-tight text-[#D5CEA3] mb-20">
          The Beanz<br/>Process
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">
          {steps.map(({ step, title, desc }) => (
            <div class="group">
              <p class="font-['JetBrains_Mono'] text-6xl font-bold text-[#E57C23]/20 mb-6 group-hover:text-[#E57C23]/40 transition-colors select-none">{step}</p>
              <h3 class="font-serif text-xl font-black uppercase italic text-[#D5CEA3] mb-4">{title}</h3>
              <div class="w-8 h-0.5 bg-[#E57C23] mb-4" aria-hidden="true"></div>
              <p class="text-[#D5CEA3]/60 text-sm leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>

        <!-- Stats -->
        <div class="mt-24 pt-16 border-t border-[#D5CEA3]/10 grid grid-cols-2 md:grid-cols-4 gap-10">
          {[
            { stat: '12+', label: 'Farm Partners' },
            { stat: '8',   label: 'Countries Sourced' },
            { stat: '48h', label: 'Roast to Ship' },
            { stat: '85+', label: 'Min SCA Score' },
          ].map(({ stat, label }) => (
            <div class="text-center">
              <p class="font-serif text-5xl font-black text-[#E57C23] mb-2">{stat}</p>
              <p class="font-['JetBrains_Mono'] text-[10px] font-bold uppercase tracking-[0.3em] text-[#D5CEA3]/50">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Subscriptions -->
    <section id="subscribe" class="py-24 px-6 md:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-0.5 bg-[#E57C23]" aria-hidden="true"></div>
          <p class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-[0.4em] text-[#E57C23]">Never Run Out</p>
        </div>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
          <h2 class="font-serif text-5xl md:text-6xl font-black uppercase italic leading-tight text-[#3C2A21]">
            Subscribe<br/>&amp; Save 15%
          </h2>
          <p class="max-w-sm text-[#3C2A21]/65 leading-relaxed text-sm">
            Pause, skip, or cancel anytime. No lock-ins — just great coffee on your schedule.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {plans.map(({ name, price, freq, bags, desc, highlight }) => (
            <div class={`rounded-3xl p-8 flex flex-col border-2 transition-all
              ${highlight
                ? 'bg-[#3C2A21] text-[#D5CEA3] border-[#E57C23] shadow-2xl scale-[1.02]'
                : 'bg-[#F5F0E8] border-[#3C2A21]/10 hover:border-[#E57C23]'
              }`}
            >
              {highlight && (
                <span class="font-['JetBrains_Mono'] text-[10px] font-bold uppercase tracking-widest bg-[#E57C23] text-white px-3 py-1 rounded-full self-start mb-6">
                  Most Popular
                </span>
              )}
              <h3 class={`font-serif text-2xl font-black uppercase italic mb-2 ${highlight ? 'text-[#D5CEA3]' : 'text-[#3C2A21]'}`}>
                {name}
              </h3>
              <p class={`font-['JetBrains_Mono'] text-[10px] uppercase tracking-widest mb-6 ${highlight ? 'text-[#D5CEA3]/50' : 'text-[#3C2A21]/50'}`}>
                {bags} per delivery
              </p>
              <div class="flex items-end gap-1 mb-6">
                <span class={`font-serif text-5xl font-black ${highlight ? 'text-[#D5CEA3]' : 'text-[#3C2A21]'}`}>{price}</span>
                <span class={`font-['JetBrains_Mono'] text-sm mb-2 ${highlight ? 'text-[#D5CEA3]/50' : 'text-[#3C2A21]/50'}`}>{freq}</span>
              </div>
              <p class={`text-sm leading-relaxed mb-8 flex-grow ${highlight ? 'text-[#D5CEA3]/70' : 'text-[#3C2A21]/65'}`}>
                {desc}
              </p>
              <a
                href="#"
                class={`font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-widest py-3 px-6 rounded-xl text-center transition-colors
                  ${highlight
                    ? 'bg-[#E57C23] text-white hover:bg-[#cf6d1a]'
                    : 'bg-[#3C2A21] text-[#D5CEA3] hover:bg-[#E57C23]'
                  }`}
              >
                Get Started
              </a>
            </div>
          ))}
        </div>

        <p class="text-center font-['JetBrains_Mono'] text-[11px] text-[#3C2A21]/40 uppercase tracking-widest mt-10">
          Free shipping on all subscriptions &middot; Cancel anytime &middot; Freshness guaranteed
        </p>
      </div>
    </section>

    <!-- About -->
    <section class="py-24 px-6 md:px-8 bg-[#D5CEA3]/20">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-0.5 bg-[#E57C23]" aria-hidden="true"></div>
            <p class="font-['JetBrains_Mono'] text-[11px] font-bold uppercase tracking-[0.4em] text-[#E57C23]">Our Story</p>
          </div>
          <h2 class="font-serif text-5xl md:text-6xl font-black uppercase italic leading-tight text-[#3C2A21] mb-8">
            Obsessed<br/>with the bean.
          </h2>
          <p class="text-[#3C2A21]/70 leading-relaxed mb-6">
            Beanz started in 2018 when founder Mara Chen left her finance career to follow a three-week sourcing trip through Ethiopia into a full-time obsession. What began as a single-drum roaster in a Portland garage is now a small roastery supplying cafés, restaurants, and homes across the Pacific Northwest.
          </p>
          <p class="text-[#3C2A21]/70 leading-relaxed mb-10">
            We believe great coffee tells a story — of the farmer who grew it, the altitude that shaped it, and the care that went into getting it into your cup without losing anything along the way.
          </p>
          <a href="#process" class="font-serif text-[#E57C23] font-black uppercase italic tracking-widest flex items-center gap-2 group">
            See How We Roast
            <svg class="w-5 h-5 group-hover:translate-x-2 transition-transform" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 10h12M10 4l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-4" aria-hidden="true">
          <div class="space-y-4">
            <div class="aspect-square bg-[#D5CEA3] rounded-2xl overflow-hidden">
              <Image src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=500&h=500" alt="" width={500} height={500} loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="aspect-[3/4] bg-[#D5CEA3] rounded-2xl overflow-hidden translate-x-4">
              <Image src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?auto=format&fit=crop&q=80&w=500&h=660" alt="" width={500} height={660} loading="lazy" class="w-full h-full object-cover" />
            </div>
          </div>
          <div class="space-y-4 pt-8">
            <div class="aspect-[3/4] bg-[#D5CEA3] rounded-2xl overflow-hidden -translate-x-4">
              <Image src="https://images.unsplash.com/photo-1574226516831-e1dff420e562?auto=format&fit=crop&q=80&w=500&h=660" alt="" width={500} height={660} loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="aspect-square bg-[#D5CEA3] rounded-2xl overflow-hidden">
